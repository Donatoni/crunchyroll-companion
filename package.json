{
  "name": "crunchyroll-companion",
  "version": "0.2.11",
  "description": "All-in-one Crunchyroll enhancement extension: auto-skip intro/outro/recap/preview and auto-play next episode.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts tests",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test && node scripts/build.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.12",
    "@types/node": "^22.5.0",
    "esbuild": "^0.21.5",
    "eslint": "^10.6.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
